{
  "name": "next-starter",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "prisma:pull": "dotenv -e .env.local -- npx prisma db pull",
    "prisma:push": "dotenv -e .env.local -- npx prisma db push",
    "prisma:migratedev": "dotenv -e .env.local -- npx prisma migrate dev",
    "prisma:migratedeploy": "dotenv -e .env.local -- npx prisma migrate deploy",
    "prisma:seed": "dotenv -e .env.local -- tsx prisma/seed.ts",
    "prisma:pull:prod": "dotenv -e .env -- npx prisma db pull",
    "prisma:push:prod": "dotenv -e .env -- npx prisma db push",
    "prisma:migratedev:prod": "dotenv -e .env -- npx prisma migrate dev",
    "prisma:migratedeploy:prod": "dotenv -e .env -- npx prisma migrate deploy",
    "prisma:seed:prod": "dotenv -e .env -- tsx prisma/seed.ts",
    "postinstall": "prisma generate"
  },

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  phone_number String?  @unique
  is_verified  Boolean
  password     String?
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt
  role         Role     @default(CUSTOMER)

  articles Article[]
  orders   Order[]
  cart     Cart?

  tokens Token[]
}

model Token {
  id          String       @id @default(uuid())
  token       String       @unique
  last_sent   DateTime?
  sent_count  Int          @default(0)
  purpose     TokenPurpose
  expiry_date DateTime

  user    User   @relation(fields: [user_id], references: [id], onDelete: Cascade)
  user_id String @unique

  @@unique([user_id, purpose])
}

model Product {
  id          String          @id @default(uuid())
  name        String
  description String
  price       Float
  stock       Int
  category    ProductCategory
  slug        String          @unique
  is_public   Boolean         @default(false)
  created_at  DateTime        @default(now())
  updated_at  DateTime        @updatedAt

  custom_options CustomOption[]
  order_products OrderItem[]
}

model Material {
  id      String    @id @default(uuid())
  name    String
  price   Float
}

model CustomOption {
  id         String   @id @default(uuid())
  size       String
  color      String
  photo      String
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  product    Product     @relation(fields: [product_id], references: [id], onDelete: Cascade)
  product_id String
  items      OrderItem[]

  @@unique([product_id, color, size])
}

model Model {
  id          String    @id @default(uuid())
  model       String
  description String
}

model CustomRequest {
  id       String @id @default(uuid())
  material String
  model    String
  color    String
  width    String
  height   String
  price    Float
  size     String
}

model Order {
  id          String      @id @default(uuid())
  created_at  DateTime    @default(now())
  updated_at  DateTime    @updatedAt
  finished_at DateTime?
  total_price Float
  status      OrderStatus

  user     User        @relation(fields: [user_id], references: [id], onDelete: Cascade)
  user_id  String
  products OrderItem[]
  payment  Payment?
  shipment Shipment?
}

model OrderItem {
  id       String @id @default(uuid())
  quantity Int

  product          Product       @relation(fields: [product_id], references: [id], onDelete: Cascade)
  product_id       String
  order            Order         @relation(fields: [order_id], references: [id], onDelete: Cascade)
  order_id         String
  custom_option    CustomOption? @relation(fields: [custom_option_id], references: [id], onDelete: Cascade) // Jika user menginginkan custom option yang baru
  custom_option_id String?
}

model Article {
  id           String   @id @default(uuid())
  title        String
  slug         String   @unique
  tags         String[]
  content      String
  cover_url    String
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt
  is_published Boolean  @default(false)
  views        Int      @default(0)

  author    User   @relation(fields: [author_id], references: [id], onDelete: Cascade)
  author_id String
}

model Payment {
  id             String        @id @default(uuid())
  method         PaymentMethod
  status         PaymentStatus
  created_at     DateTime      @default(now())
  transaction_id String? // ID Transaksi dari payment gateway

  order    Order  @relation(fields: [order_id], references: [id], onDelete: Cascade)
  order_id String @unique
}

model Shipment {
  id          String         @id @default(uuid())
  carrier     String // Nama pengirim (i.e: JNE, J&T)
  tracking_id String? // ID Tracking dari third party
  status      ShipmentStatus
  created_at  DateTime       @default(now())
  updated_at  DateTime       @updatedAt

  order    Order  @relation(fields: [order_id], references: [id], onDelete: Cascade)
  order_id String @unique
}

model Cart {
  id           String @id @default(uuid())
  user         User   @relation(fields: [user_id], references: [id], onDelete: Cascade)
  user_id      String @unique
  json_content Json
}

// cart: [
// {
//  productId: string,
//  quantity: string,
//  isSelected: boolean, ini tak masuk db cookie aja
//  productOptionsId: string
// }
// ],

model SEO {
  id                 Int      @id @default(autoincrement())
  page               String   @unique
  title              String
  description        String
  keywords           String[]
  canonicalURL       String?
  ogTitle            String?
  ogDescription      String?
  ogImage            String?
  twitterCard        String? // Summary, Summary_large_image, etc.
  twitterTitle       String?
  twitterDescription String?
  twitterImage       String?
  updatedAt          DateTime @updatedAt
  createdAt          DateTime @default(now())
}

enum Role {
  CUSTOMER
  ADMIN
  SUPERADMIN
  SALES
  CONTENTWRITER
}

enum ProductCategory {
  READY_STOCK
  CUSTOM
}

enum OrderStatus {
  UNPAID // Belum dibayar
  PENDING // Sudah dibayar, belum diapprove sales
  PACKING // sudah diapprove sales
  SHIPPING // Order bersama kurir
  DELIVERED // Telah dikirim di alamat tujuan
  FINISHED // Telah selesai
  CANCELED // Dibatalkan (jika sebelum packing)
}

enum PaymentMethod {
  CREDIT_CARD
  DEBIT_CARD
  BANK_TRANSFER
  QRIS
  E_WALLET
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
}

enum ShipmentStatus {
  PENDING
  SHIPPED
  DELIVERED
  CANCELED
}

enum TokenPurpose {
  RESET_PASSWORD
  EMAIL_VERIFICATION
}

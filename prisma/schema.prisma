generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  phone_number String?  @unique
  is_verified  Boolean
  password     String?
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt
  role         Role     @default(CUSTOMER)

  articles Article[]
  orders   Order[]
  cart     Cart?

  tokens            Token[]
  shipping_addreses ShippingAddress[]
}

model Token {
  id          String       @id @default(uuid())
  token       String       @unique
  last_sent   DateTime?
  sent_count  Int          @default(0)
  purpose     TokenPurpose
  expiry_date DateTime

  user    User   @relation(fields: [user_id], references: [id], onDelete: Cascade)
  user_id String @unique

  @@unique([user_id, purpose])
}

model ProductCategory {
  id         String   @id @default(uuid())
  name       String
  image      String
  slug       String   @unique
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  products Product[]
}

model Product {
  id           String   @id @default(uuid())
  name         String
  description  String
  slug         String   @unique
  is_published Boolean  @default(false)
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  category        ProductCategory  @relation(fields: [category_id], references: [id], onDelete: Cascade)
  category_id     String
  variants        ProductVariant[]
  custom_products CustomProduct[]
  reviews         Review[]
}

model Review {
  id      String @id @default(uuid())
  rating  Float
  content String

  order_id      String
  order         Order     @relation(fields: [order_id], references: [id])
  order_item_id String    @unique
  order_item    OrderItem @relation(fields: [order_item_id], references: [id], onDelete: Cascade)
  product_id    String
  product       Product   @relation(fields: [product_id], references: [id], onDelete: Cascade)

  @@unique([order_item_id, order_id])
}

model ProductVariant {
  id         String   @id @default(uuid())
  size       String
  color      String
  photo      String
  price      Float
  stock      Int
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  product    Product     @relation(fields: [product_id], references: [id], onDelete: Cascade)
  product_id String
  items      OrderItem[]

  @@unique([product_id, color, size])
}

model CustomProduct {
  id    String @id @default(uuid())
  size  String
  color String

  product_id String
  product    Product     @relation(fields: [product_id], references: [id], onDelete: Cascade)
  order_id   String      @unique
  order      Order       @relation(fields: [order_id], references: [id], onDelete: Cascade)
  items      OrderItem[]
}

model ShippingAddress {
  id                     String   @id @default(uuid())
  recipient_name         String
  recipient_phone_number String
  created_at             DateTime @default(now())
  updated_at             DateTime @updatedAt

  street          String
  city            String
  region          String
  postal_code     String
  additional_info String?
  is_primary      Boolean @default(false)

  user_id String
  user    User   @relation(fields: [user_id], references: [id], onDelete: Cascade)

  orders Order[]
}

model Order {
  id                    String      @id @default(uuid())
  estimated_finish_time DateTime
  finished_at           DateTime?
  total_price           Float
  status                OrderStatus
  created_at            DateTime    @default(now())
  updated_at            DateTime    @updatedAt

  reviews        Review[]
  items          OrderItem[]
  custom_product CustomProduct?
  payment        Payment?
  shipment       Shipment?

  user                User            @relation(fields: [user_id], references: [id], onDelete: Cascade)
  user_id             String
  shipping_address    ShippingAddress @relation(fields: [shipping_address_id], references: [id], onDelete: Cascade)
  shipping_address_id String
}

model OrderItem {
  id       String @id @default(uuid())
  quantity Int

  review            Review?
  order             Order           @relation(fields: [order_id], references: [id], onDelete: Cascade)
  order_id          String
  custom_option     ProductVariant? @relation(fields: [custom_option_id], references: [id], onDelete: Cascade) // Jika user menginginkan custom option yang baru
  custom_option_id  String?
  custom_product    CustomProduct?  @relation(fields: [custom_product_id], references: [id], onDelete: Cascade) // Jika user menginginkan custom option yang baru
  custom_product_id String?
}

model Article {
  id           String    @id @default(uuid())
  title        String
  slug         String    @unique
  tags         String[]
  content      String
  cover_url    String
  published_at DateTime?
  created_at   DateTime  @default(now())
  updated_at   DateTime  @updatedAt
  is_published Boolean   @default(false)
  views        Int       @default(0)
  description  String

  author    User   @relation(fields: [author_id], references: [id], onDelete: Cascade)
  author_id String
}

model Payment {
  id             String        @id @default(uuid())
  method         PaymentMethod
  status         PaymentStatus
  created_at     DateTime      @default(now())
  transaction_id String? // ID Transaksi dari payment gateway

  order    Order  @relation(fields: [order_id], references: [id], onDelete: Cascade)
  order_id String @unique
}

model Shipment {
  id          String         @id @default(uuid())
  carrier     String // Nama pengirim (i.e: JNE, J&T)
  tracking_id String? // ID Tracking dari third party
  status      ShipmentStatus
  created_at  DateTime       @default(now())
  updated_at  DateTime       @updatedAt

  order    Order  @relation(fields: [order_id], references: [id], onDelete: Cascade)
  order_id String @unique
}

model Cart {
  id           String @id @default(uuid())
  user         User   @relation(fields: [user_id], references: [id], onDelete: Cascade)
  user_id      String @unique
  json_content Json
}

// cart: [
// {
//  productId: string,
//  quantity: string,
//  isSelected: boolean, ini tak masuk db cookie aja
//  productOptionsId: string
// }
// ],

model SEO {
  id                 Int      @id @default(autoincrement())
  page               String   @unique
  title              String
  description        String
  keywords           String[]
  canonicalURL       String?
  ogTitle            String?
  ogDescription      String?
  ogImage            String?
  twitterCard        String? // Summary, Summary_large_image, etc.
  twitterTitle       String?
  twitterDescription String?
  twitterImage       String?
  updatedAt          DateTime @updatedAt
  createdAt          DateTime @default(now())
}

enum Role {
  CUSTOMER
  ADMIN
  SUPERADMIN
  SALES
  CONTENTWRITER
}

enum OrderStatus {
  UNPAID // Belum dibayar
  PENDING // Sudah dibayar, belum diapprove sales
  PACKING // sudah diapprove sales
  SHIPPING // Order bersama kurir
  DELIVERED // Telah dikirim di alamat tujuan
  FINISHED // Telah selesai
  CANCELED // Dibatalkan (jika sebelum packing)
}

enum PaymentMethod {
  CREDIT_CARD
  DEBIT_CARD
  BANK_TRANSFER
  QRIS
  E_WALLET
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
}

enum ShipmentStatus {
  PENDING
  SHIPPED
  DELIVERED
  CANCELED
}

enum TokenPurpose {
  RESET_PASSWORD
  EMAIL_VERIFICATION
}

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  phone_number String   @unique
  password     String
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  role                Role      @default(CUSTOMER)
  articles            Article[]
  orders              Order[]
  cart                Cart?
  forgot_password_otp String?
}

model Product {
  id          String          @id @default(uuid())
  name        String
  description String
  price       Float
  stock       Int
  category    ProductCategory
  is_custom   Boolean
  slug        String          @unique
  is_public   Boolean         @default(false)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  custom_options CustomOption[]
  order_products OrderItem[]
}

model CustomOption {
  id         String   @id @default(uuid())
  size       String?
  color      String?
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  product    Product     @relation(fields: [product_id], references: [id])
  product_id String
  items      OrderItem[]

  @@unique([product_id, color, size])
}

model Order {
  id          String      @id @default(uuid())
  created_at  DateTime    @default(now())
  updated_at  DateTime    @updatedAt
  finished_at DateTime?
  status      OrderStatus

  user        User        @relation(fields: [user_id], references: [id])
  user_id     String
  products    OrderItem[]
  total_price Float
  payment     Payment?
  shipment    Shipment?
}

model OrderItem {
  id       String @id @default(uuid())
  quantity Int

  product          Product       @relation(fields: [product_id], references: [id])
  product_id       String
  order            Order         @relation(fields: [order_id], references: [id])
  order_id         String
  custom_option    CustomOption? @relation(fields: [custom_option_id], references: [id]) // Jika user menginginkan custom option yang baru
  custom_option_id String?
}

model Article {
  id           String    @id @default(uuid())
  title        String
  slug         String    @unique
  tags         String[]
  content      String
  cover_url    String
  created_at   DateTime  @default(now())
  updated_at   DateTime?
  is_published Boolean   @default(false)

  author    User   @relation(fields: [author_id], references: [id])
  author_id String
}

model Payment {
  id             String        @id @default(uuid())
  method         PaymentMethod
  status         PaymentStatus
  created_at     DateTime      @default(now())
  transaction_id String? // ID Transaksi dari payment gateway

  order    Order  @relation(fields: [order_id], references: [id])
  order_id String @unique
}

model Shipment {
  id          String         @id @default(uuid())
  carrier     String // Nama pengiri (i.e: JNE, J&T)
  tracking_id String? // ID Tracking dari third party
  status      ShipmentStatus
  created_at  DateTime       @default(now())
  updated_at  DateTime       @updatedAt

  order    Order  @relation(fields: [order_id], references: [id])
  order_id String @unique
}

model Cart {
  id           String @id @default(uuid())
  user         User   @relation(fields: [user_id], references: [id])
  user_id      String @unique
  json_content Json
}

// cart: [
// {
//  productId: string,
//  quantity: string,
//  isSelected: boolean, ini tak masuk db cookie aja
//  productOptionsId: string
// }
// ],

enum Role {
  CUSTOMER
  ADMIN
  SUPERADMIN
  SALES
  CONTENTWRITER
}

enum ProductCategory {
  READY_STOCK
  CUSTOM
}

enum OrderStatus {
  UNPAID // Belum dibayar
  PENDING // Sudah dibayar, belum diapprove sales
  PACKING // sudah diapprove sales
  SHIPPING // Order bersama kurir
  DELIVERED // Telah dikirim di alamat tujuan
  FINISHED // Telah selesai
  CANCELED // Dibatalkan (jika sebelum packing)
}

enum PaymentMethod {
  CREDIT_CARD
  DEBIT_CARD
  BANK_TRANSFER
  QRIS
  E_WALLET
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
}

enum ShipmentStatus {
  PENDING
  SHIPPED
  DELIVERED
  CANCELED
}
